def add_numbers(a, b):
    """Возвращает сумму двух чисел."""
    return a + b

print(add_numbers(5, 3),"#1")
#2
def calculate_average(numbers):
    if not numbers:  
        return 0
    return sum(numbers) / len(numbers)

print(calculate_average([1, 2, 3, 4, 5]),"#2")   
#3
def fibonacci(n):
    
    if n < 0:
        raise ValueError("n должно быть неотрицательным числом")
    if n == 0:
        return 0
    elif n == 1:
        return 1
    else:
        return fibonacci(n - 1) + fibonacci(n - 2)


print(fibonacci(6),"#3") 
#4
def multiply_all(*args):
    result = 1
    for number in args:
        result *= number
    return result

print(multiply_all(2, 3, 4),"#4")  


counter = 0
#5
def increment_counter(increment=1):
    
    global counter
    counter += increment
    return counter

print("Начальное значение:", counter, "#5")  
print("После увеличения на 5:", increment_counter(5),"#5") 
print("После стандартного увеличения:", increment_counter(),"#5")  
print("Текущее значение counter:", counter, "#5")  
